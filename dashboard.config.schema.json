{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Jwan999/dashboard-kit/schema/v1",
  "title": "dashboard.config.json",
  "description": "Configuration produced by the dashboard-kit wizard. Persisted at the host project root and consumed by the generator. Versioned via the top-level `version` field; the generator must support reading older majors for at least one major back.",
  "type": "object",
  "required": ["version", "identity", "language", "brand", "visual", "architecture", "data", "operational"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "string",
      "description": "Schema version. Major bumps indicate breaking changes; the generator preserves backward compatibility for one major behind the current one.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "identity": {
      "type": "object",
      "required": ["displayName", "machineName"],
      "properties": {
        "displayName": { "type": "string" },
        "machineName": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
        "description": { "type": "string" },
        "logoLight": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          ]
        },
        "logoDark": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          ]
        },
        "logoDarkDerived": { "type": "boolean" },
        "domain": { "type": "string" },
        "routePrefix": { "type": "string" }
      }
    },
    "language": {
      "type": "object",
      "required": ["languages", "defaultLanguage", "direction"],
      "properties": {
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 2, "maxLength": 5 }
        },
        "defaultLanguage": { "type": "string" },
        "direction": { "type": "string", "enum": ["rtl", "ltr", "auto"] },
        "fallbackLocale": { "type": "string" }
      }
    },
    "brand": {
      "type": "object",
      "required": ["primary", "primaryScale", "neutral", "semantic", "fontLatin", "fontArabic"],
      "properties": {
        "primary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "primaryScale": {
          "type": "object",
          "patternProperties": {
            "^(50|100|200|300|400|500|600|700|800|900)$": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
          }
        },
        "accent": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
          ]
        },
        "neutral": { "type": "string", "enum": ["cool", "warm", "true", "slate"] },
        "semantic": {
          "type": "object",
          "required": ["success", "warning", "error", "info"],
          "properties": {
            "success": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "warning": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "error": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "info": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
          }
        },
        "fontLatin": { "type": "string" },
        "fontArabic": { "type": "string" },
        "fontHosting": { "type": "string", "enum": ["self", "cdn"] }
      }
    },
    "visual": {
      "type": "object",
      "required": ["radius", "density", "shadow", "motion"],
      "properties": {
        "radius": { "type": "string", "enum": ["sharp", "subtle", "rounded", "pill"] },
        "density": { "type": "string", "enum": ["comfortable", "default", "compact"] },
        "shadow": { "type": "string", "enum": ["flat", "soft", "layered"] },
        "motion": { "type": "string", "enum": ["minimal", "standard", "expressive"] }
      }
    },
    "architecture": {
      "type": "object",
      "required": ["integrationModel", "auth"],
      "properties": {
        "integrationModel": { "type": "string", "enum": ["inertia", "spa"] },
        "auth": { "type": "string", "enum": ["sanctum-cookie", "sanctum-tokens", "external-idp"] },
        "multiTenant": { "type": "boolean" },
        "tenancyStrategy": { "type": "string", "enum": ["path", "subdomain", "header"] }
      }
    },
    "data": {
      "type": "object",
      "required": ["chartsLibrary", "tables", "realTime"],
      "properties": {
        "chartsLibrary": { "type": "string", "enum": ["echarts", "chartjs", "apexcharts", "recharts"] },
        "tables": {
          "type": "object",
          "properties": {
            "pagination": { "type": "boolean" },
            "bulkActions": { "type": "boolean" },
            "rowSelection": { "type": "boolean" },
            "export": { "type": "boolean" }
          }
        },
        "realTime": { "type": "string", "enum": ["none", "polling", "websockets"] }
      }
    },
    "operational": {
      "type": "object",
      "properties": {
        "deploymentTarget": { "type": "string" },
        "performanceBudget": { "type": "string", "enum": ["standard", "slow"] },
        "accessibility": { "type": "boolean" }
      }
    }
  }
}